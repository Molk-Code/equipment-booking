# Resend Configuration (for sending booking emails with PDF attachment)
# Sign up at https://resend.com/ (free: 100 emails/day)
# Add your API key below:

RESEND_API_KEY=re_your_api_key_here

# Google Sheets API (for inventory system write access)
# Create a service account at https://console.cloud.google.com/
# Enable Google Sheets API, create credentials, download JSON key
# Share the spreadsheet with the service account email as Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n
